# Copy to .env and fill in values — never commit .env

# ── Wallets ──────────────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
MANAGER_WALLET=0xYOUR_MANAGER_WALLET_ADDRESS
MINTER_KEY=0xYOUR_N8N_MINTER_PRIVATE_KEY  # Grant MINTER_ROLE after deploy

# ── Alchemy RPC ───────────────────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
POLYGON_MAINNET_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
ALCHEMY_API_KEY=YOUR_ALCHEMY_API_KEY
ALCHEMY_AUTH_TOKEN=alcht_YOUR_ALCHEMY_AUTH_TOKEN

# ── API Keys ──────────────────────────────────────────────────────────────────
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# ── Webhooks ──────────────────────────────────────────────────────────────────
ALCHEMY_WEBHOOK_SIGNING_KEY=whsec_YOUR_SIGNING_KEY
WEBHOOK_URL=https://your-ngrok-domain.ngrok-free.dev
WEBHOOK_PORT=4041

# ── Contract addresses (populated after deploy) ───────────────────────────────
CONTRACT_EQUITY=
CONTRACT_NOTE=
CONTRACT_SHTX=
CONTRACT_TRACK=
CONTRACT_LOYALTY=

# ── Integrations ──────────────────────────────────────────────────────────────
WEB3AUTH_CLIENT_ID=YOUR_WEB3AUTH_CLIENT_ID
SEQUENCE_PROJECT_KEY=YOUR_SEQUENCE_PROJECT_KEY  # from sequence.build project Settings tab

# ── Optional ──────────────────────────────────────────────────────────────────
REPORT_GAS=true